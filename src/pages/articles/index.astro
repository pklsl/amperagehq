---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Articles"
  description="Browse all AmperageHQ articles on electrical wiring, NEC code, safety, and DIY guides."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4 font-heading">Electrical Articles</h1>
    <p class="text-text-muted mb-10">
      Expert guides and practical advice on wiring, electrical code, tools, and safety.
    </p>

    <AdSlot slot="articles-top" format="horizontal" lazy={false} minHeight="90px" className="mb-10" />

    {articles.length === 0 ? (
      <p class="text-text-muted">Articles coming soon. Check back shortly.</p>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article) => (
          <a
            href={`/articles/${article.id}`}
            class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow p-6 block"
          >
            <time
              class="text-sm text-text-muted"
              datetime={article.data.pubDate.toISOString()}
            >
              {article.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h2 class="text-lg font-semibold mt-2 mb-2">{article.data.title}</h2>
            <p class="text-text-muted text-sm">{article.data.description}</p>
            {article.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1">
                {article.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs bg-primary/10 text-primary-dark px-2 py-0.5 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
